{
  "realm": "quadboard",
  "enabled": true,

  "displayName": "QuadBoard",

  "groups": [
    {
      "name": "admins"
    }
  ],

  "users": [
    {
      "username": "admin",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Quad",
      "lastName": "Admin",
      "email": "admin@quadboard.local",

      "credentials": [
        {
          "type": "password",
          "value": "admin123",
          "temporary": false
        }
      ],

      "groups": [
        "/admins"
      ]
    }
  ],

  "clients": [
    {
      "clientId": "quadboard",
      "name": "QuadBoard",
      "enabled": true,

      "protocol": "openid-connect",

      "publicClient": false,

      "secret": "super-secret",

      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,

      "redirectUris": [
        "http://domain.local:8081/auth/callback"
      ],

      "webOrigins": [
        "http://domain.local:8081"
      ],

      "attributes": {
        "pkce.code.challenge.method": "S256"
      },

      "defaultClientScopes": [
        "profile",
        "email",
        "roles"
      ],

      "optionalClientScopes": [
        "groups"
      ],

      "protocolMappers": [
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "consentRequired": false,
          "config": {
            "full.path": "false",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true",
            "claim.name": "groups"
          }
        }
      ]
    }
  ]
}
